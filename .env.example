# ====== LINE Messaging API ======
# จาก LINE Developers Console > Channel ของคุณ
LINE_CHANNEL_ACCESS_TOKEN=ใส่_channel_access_token_ที่นี่
LINE_CHANNEL_SECRET=ใส่_channel_secret_ที่นี่

# ====== OCR.space (ดึงข้อความไทยจากรูปบิล) ======
# สมัครฟรีที่ https://ocr.space/ocrapi/freekey
OCR_SPACE_API_KEY=ใส่_ocr_space_key_ที่นี่
# ภาษาไทยต้องใช้ language=auto คู่กับ Engine 2 (ห้ามใช้ tha กับ Engine 1)
OCR_SPACE_LANGUAGE=auto
OCR_SPACE_ENGINE=2

# ====== Groq (จัดข้อความให้เป็นข้อมูลมีโครงสร้าง) ======
# สมัครฟรีที่ https://console.groq.com/keys
GROQ_API_KEY=ใส่_groq_key_ที่นี่
GROQ_MODEL=llama-3.3-70b-versatile

# ====== Google Sheets (เก็บข้อมูลบิล) ======
# ID ของ Google Sheet (อยู่ใน URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=ใส่_sheet_id_ที่นี่
# ชื่อชีต (แท็บด้านล่าง) ค่าเริ่มต้น Bills
GOOGLE_SHEET_NAME=Bills
# ข้อมูล service account แบบ JSON ทั้งก้อน (วางทั้งบรรทัดเดียว)
# จากไฟล์ JSON ที่ดาวน์โหลดจาก Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# ====== ทั่วไป ======
PORT=3000
# เขตเวลา (ใช้ตีความวันที่บิล) ค่าเริ่มต้นเวลาไทย
TZ=Asia/Bangkok
